---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

const currentPath = Astro.url.pathname;
const onProjectPage = currentPath.startsWith('/projects/');
---

<header class="site-nav">
  <nav aria-label="Primary">
    <a
      href="/"
      class="ink-chip brand"
      aria-label="The Angel You Need — home"
      aria-current={currentPath === '/' ? 'page' : undefined}
    >
      <span class="brand-mark" aria-hidden="true">✦</span>
      <span class="brand-text">The Angel You Need</span>
    </a>

    <ul class="nav-links">
      <li>
        <details class="project-index">
          <summary
            class="ink-chip"
            aria-label="Project index"
            data-current={onProjectPage ? 'page' : undefined}
          >
            <span>Projects</span>
            <span aria-hidden="true" class="chev">▾</span>
          </summary>
          <ul class="project-panel">
            {
              projects.map((project) => (
                <li>
                  <a
                    href={`/projects/${project.id}`}
                    data-island-slug={project.id}
                    aria-current={
                      currentPath === `/projects/${project.id}` ? 'page' : undefined
                    }
                  >
                    <span class="project-name">{project.data.title}</span>
                    <span class="project-meta">{project.data.category}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </details>
      </li>
      <li>
        <a
          href="/about"
          class="ink-chip"
          aria-current={currentPath === '/about' ? 'page' : undefined}
        >
          About
        </a>
      </li>
      <li>
        <a
          href="/contact"
          class="ink-chip"
          aria-current={currentPath === '/contact' ? 'page' : undefined}
        >
          Contact
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-nav {
    position: fixed;
    inset: 0 0 auto 0;
    /* Above the interior-scene overlay (30) so the brand link stays
       clickable as a "back to home" exit while a project scene is open. */
    z-index: 35;
    padding: 1rem 1.5rem;
    pointer-events: none;
  }
  .site-nav nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1400px;
    margin: 0 auto;
    pointer-events: auto;
  }

  /* Brand — uses .ink-chip aesthetic but keeps its own serif typography
     and a larger frame so it reads as a logotype rather than a button. */
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1rem;
    padding: 6px 12px;
  }
  .brand-mark {
    font-family: var(--font-display);
    color: var(--gabo-halo);
    font-size: 1.25rem;
    line-height: 1;
    /* Webkit-only stroke keeps the halo mark readable on the cream
       chip surface in Chrome/Safari/Edge. Firefox falls back to the
       solid gold fill, which still passes contrast against cream. */
    -webkit-text-stroke: 1px var(--ink);
  }

  /* Nav link cluster — no container chrome; each link is a discrete
     ink-chip floating on the sky. Slightly larger typography than the
     default .ink-chip (which is sized for in-card buttons). */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-links .ink-chip {
    font-size: 0.85rem;
    padding: 6px 12px;
  }

  /* Active state — fill with the per-project sky accent (or default
     --sky-accent on home/about/contact). Keeps the ink border and hard
     shadow; just swaps the surface color so the chip reads as "current". */
  .nav-links .ink-chip[aria-current='page'],
  .nav-links .ink-chip[data-current='page'],
  .brand[aria-current='page'] {
    background: var(--sky-accent);
  }

  /* Disclosure trigger */
  .project-index {
    position: relative;
  }
  .project-index > summary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    list-style: none;
  }
  .project-index > summary::-webkit-details-marker {
    display: none;
  }
  .project-index .chev {
    font-size: 0.75em;
    line-height: 1;
  }
  @media (prefers-reduced-motion: no-preference) {
    .project-index .chev {
      transition: transform var(--dur-fast) var(--ease-cloud);
    }
    .project-index[open] .chev {
      transform: rotate(180deg);
    }
  }

  /* Open panel — square pearl card with hard offset shadow. Medium
     weights (3.5px border, 4px shadow) so the fixed-top nav doesn't
     feel oppressive; lg weights are reserved for in-page .ink-card. */
  .project-panel {
    list-style: none;
    margin: 0;
    padding: 6px;
    display: none;
  }
  .project-index[open] > .project-panel {
    display: grid;
    gap: 2px;
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    min-width: 16rem;
    background: var(--cumul-base);
    border: var(--ink-border-bold) solid var(--ink);
    border-radius: var(--radius-sharp);
    box-shadow: var(--ink-shadow-md);
  }
  .project-panel a {
    display: grid;
    gap: 2px;
    padding: 8px 10px;
    text-decoration: none;
    color: var(--ink);
    border-radius: var(--radius-sharp);
    font-family: var(--font-sans);
  }
  .project-panel a:hover {
    background: color-mix(in srgb, var(--sky-accent) 28%, transparent);
  }
  .project-panel a[aria-current='page'] {
    background: var(--sky-accent);
    font-weight: 600;
  }
  .project-name {
    font-size: 0.92rem;
    font-weight: 500;
  }
  .project-meta {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.6;
  }

  @media (max-width: 640px) {
    .site-nav {
      padding: 0.75rem 1rem;
    }
    .brand-text {
      display: none;
    }
    .nav-links {
      gap: 0.4rem;
    }
    .nav-links .ink-chip {
      font-size: 0.78rem;
      padding: 5px 9px;
    }
  }
</style>
