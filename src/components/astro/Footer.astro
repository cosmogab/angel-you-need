<style>
  .site-footer {
    padding: 2rem 1.5rem 2.5rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--ink);
  }
  .site-footer p {
    margin: 0.25rem 0;
  }
  .mark {
    font-family: var(--font-display);
    color: var(--gabo-halo);
    margin-right: 0.25rem;
  }
  .quiet {
    opacity: 0.7;
    font-size: 0.82rem;
  }
  .quiet a {
    color: inherit;
  }
</style>
