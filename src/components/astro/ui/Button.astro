---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  ariaLabel?: string;
}

const {
  href,
  type = 'button',
  class: className = '',
  ariaLabel,
} = Astro.props;
---

{
  href ? (
    <a class:list={['ink-chip', className]} href={href} aria-label={ariaLabel}>
      <slot />
    </a>
  ) : (
    <button class:list={['ink-chip', className]} type={type} aria-label={ariaLabel}>
      <slot />
    </button>
  )
}
